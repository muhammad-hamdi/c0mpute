{
  "name": "c0mpute-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*/web"
  ],
  "scripts": {
    "dev:web": "bun run --filter=c0mpute dev",
    "dev:coordinator": "bun run --cwd apps/coordinator dev",
    "build": "bun run --cwd packages/shared build && bun run --filter=c0mpute build",
    "start": "bun run --filter=c0mpute start",
    "lint": "bun run --cwd apps/coordinator lint",
    "cargo:build": "cargo build --bins",
    "cargo:run": "cargo run --bin c0mpute --",
    "cargo:test": "cargo test --workspace"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
